# ===========================================
# LucidByte - Переменные Окружения
# ===========================================

# ===========================================
# API Ключи (НЕ КОММИТИТЬ В РЕПОЗИТОРИЙ!)
# ===========================================

# VirusTotal API (опционально, для расширенной базы хешей)
# Получить ключ: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# MalwareBazaar API (опционально, для автоматической загрузки)
# Получить ключ: https://bazaar.abuse.ch/api/
MALWAREBAZAAR_API_KEY=

# ===========================================
# Прокси Настройки (опционально)
# ===========================================
HTTP_PROXY=
HTTPS_PROXY=

# ===========================================
# Пути к Внешним Инструментам
# ===========================================
JAVA_HOME=/usr/lib/jvm/java-11-openjdk
JADX_PATH=/opt/jadx/bin/jadx
GHIDRA_PATH=/opt/ghidra

# ===========================================
# Настройки Приложения
# ===========================================
LUCIDBYTE_DEBUG=false
LUCIDBYTE_LOG_LEVEL=INFO